    "version": "0.2.0",
    "configurations": [
        {
            "name": "server",
            "type": "debugpy",
            "request": "launch",
            "cwd": "${workspaceFolder}/anonymizer",
            "program": "main.py",
            "console": "integratedTerminal",
            "env": {
                "GRPC_VERBOSITY": "debug"
            }
        },
        {
            "name": "demo-app",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/demo/my-app/app.py",
            "envFile": "${workspaceFolder}/demo/my-app/.env",
            "console": "integratedTerminal"
        }
    ]
}